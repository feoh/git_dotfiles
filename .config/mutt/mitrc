# use program "pass" to handle and decrypt passwords
# set my_pass="`pass cpatti@mit.edu`"
set my_pass="`op item get s2fi2wbaq7hlhpdiku4szaxsjm --reveal --field password`"
set imap_user = "cpatti@mit.edu"
set imap_pass = $my_pass

set smtp_pass=$my_pass

set sendmail="msmtp"
set use_from=yes

set envelope_from=yes
set from = "cpatti@mit.edu"
set realname = "Chris Patti"


set hostname = "mit.edu"
set folder = "imaps://outlook.office365.com"
set spoolfile = "+INBOX"
set move = no

# Oauth2 hoo-ha
# /home/feoh/.local/bin/mutt-oauth2
set imap_authenticators="oauthbearer:xoauth2"
set imap_oauth_refresh_command="/home/feoh/.local/bin/mutt-oauth2"
set smtp_authenticators=${imap_authenticators}
set smtp_oauth_refresh_command=${imap_oauth_refresh_command}
set sort = 'threads'
set sort_aux = 'last-date-received'
set imap_check_subscribed

set editor='nvim'

# Open URLs in emails
macro index,pager \cb "<pipe-message> urlscan<Enter>" "call urlscan to extract URLs out of a message"
macro attach,compose \cb "<pipe-entry> urlscan<Enter>" "call urlscan to extract URLs out of a message"

set signature = ~/.mit-signature
